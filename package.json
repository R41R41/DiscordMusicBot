{
  "name": "discord-music-bot",
  "version": "2.4.0",
  "description": "BGM共有 Discord Bot + Web UI",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:web": "cd web-ui && npm run dev",
    "dev:electron": "electron electron/main.cjs --dev",
    "build": "tsc",
    "build:web": "cd web-ui && npm run build",
    "build:all": "npm run build && npm run build:web",
    "start": "node dist/index.js",
    "electron": "electron electron/main.cjs",
    "clean:release": "node -e \"const fs=require('fs');const p=require('path');const d='release';if(fs.existsSync(d)){fs.readdirSync(d).forEach(f=>{const fp=p.join(d,f);fs.statSync(fp).isDirectory()?fs.rmSync(fp,{recursive:true}):fs.unlinkSync(fp)});console.log('Cleaned release folder')}\"",
    "dist": "npm run clean:release && npm run build:all && electron-builder",
    "dist:win": "npm run clean:release && npm run build:all && node --max-old-space-size=8192 ./node_modules/electron-builder/out/cli/cli.js --win"
  },
  "keywords": [
    "discord",
    "music",
    "bot"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@discordjs/voice": "^0.19.0",
    "@snazzah/davey": "^0.1.9",
    "cors": "^2.8.5",
    "discord.js": "^14.14.1",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "ffmpeg-static": "^5.2.0",
    "opusscript": "^0.1.1",
    "socket.io": "^4.7.4",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.10",
    "electron": "^40.2.1",
    "electron-builder": "^26.7.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "build": {
    "appId": "com.discord.musicbot",
    "productName": "Discord Music Bot",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "web-ui/dist/**/*",
      "data/**/*",
      "music/.gitkeep",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist",
        "to": "backend/dist"
      },
      {
        "from": "data",
        "to": "backend/data"
      },
      {
        "from": "backend-package.json",
        "to": "backend/package.json"
      },
      {
        "from": "node_modules",
        "to": "backend/node_modules"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/icon.ico",
      "signAndEditExecutable": false
    },
    "forceCodeSigning": false,
    "compression": "store",
    "nsis": {
      "oneClick": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Discord Music Bot",
      "differentialPackage": false
    }
  }
}